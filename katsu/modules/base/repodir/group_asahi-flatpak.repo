[copr:copr.fedorainfracloud.org:group_asahi:flatpak]
name=Copr repo for flatpak owned by @asahi
baseurl=https://download.copr.fedorainfracloud.org/results/@asahi/flatpak/fedora-$releasever-$basearch/
type=rpm-md
skip_if_unavailable=True
gpgcheck=1
gpgkey=https://download.copr.fedorainfracloud.org/results/@asahi/flatpak/pubkey.gpg
repo_gpgcheck=0
enabled=1
enabled_metadata=1
